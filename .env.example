# ForgeComply 360 Reporter - Environment Configuration
# Copy this file to .env and update the values

# API URL for the main ForgeComply 360 backend
# Leave empty for offline-only mode
# For staging validation, use the staging API:
# VITE_API_URL=https://forgecomply360-api-staging.workers.dev
VITE_API_URL=https://forgecomply360-api.workers.dev
